@page
@model IndexModel
@{
    ViewData["Title"] = "Wake Up to YouTube — Fresh Shorts, Specific Videos & Sleep Timer";
}

<!-- ===== HERO ===== -->
<section id="hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="display-3 fw-bold mb-3">
                    Wake up to <span class="text-accent">YouTube</span> — fresh every morning
                </h1>
                <p class="lead mb-4 text-muted-brand">
                    A fresh Short from your favorite channel every day, a specific video you choose, or a meditation video to fall asleep to. Your alarm, your content.
                </p>

                <ul class="hero-checks list-unstyled mt-3 mb-4">
                    <li><i class="lucide-check"></i> Auto-plays the <strong>newest Short</strong> from any channel daily</li>
                    <li><i class="lucide-check"></i> Set a <strong>specific video</strong> as your alarm</li>
                    <li><i class="lucide-check"></i> <strong>Multiple sleep timers</strong> for meditation &amp; ambient videos</li>
                    <li><i class="lucide-check"></i> <strong>30-day free Pro trial</strong> — all features unlocked</li>
                    <li><i class="lucide-check"></i> Set as your <strong>default Android alarm</strong> app</li>
                    <li><i class="lucide-check"></i> Survives reboots, Doze mode &amp; battery saver</li>
                </ul>

                <a href="https://play.google.com/store/apps/details?id=com.kardsen.ytshortsalarm"
                   class="btn btn-cta btn-lg"
                   target="_blank" rel="noopener noreferrer"
                   aria-label="Download YT Shorts Alarm on Google Play">
                    <i class="lucide-download" aria-hidden="true"></i> Download on Google Play
                </a>
                <p class="small text-muted-brand mt-3 mb-0"><i class="lucide-gift" style="font-size: 0.85rem;"></i> Free to try &mdash; 30-day Pro trial included</p>

            </div>
            <div class="col-lg-6 text-center mt-5 mt-lg-0">
                <img src="~/images/hero-banner.jpg" alt="YT Shorts Alarm — your morning, powered by fresh video" class="img-fluid rounded-4 shadow-lg hero-lightbox-trigger" loading="eager" role="button" tabindex="0" aria-label="Click to enlarge hero image" style="cursor: zoom-in;" />
            </div>
        </div>
    </div>
</section>

<!-- Lightbox overlay -->
<div id="heroLightbox" class="lightbox-overlay" role="dialog" aria-modal="true" aria-label="Enlarged hero image">
    <button class="lightbox-close" aria-label="Close">&times;</button>
    <img src="~/images/hero-banner.jpg" alt="YT Shorts Alarm — your morning, powered by fresh video" class="lightbox-img" />
</div>

<!-- ===== SOCIAL PROOF ===== -->
<section class="py-4">
    <div class="container">
        <div class="social-proof-strip d-flex flex-wrap justify-content-center gap-4 align-items-center text-muted-brand small">
            <span><i class="lucide-shield-check"></i> <strong style="color: var(--color-on-surface);">No ads, no tracking</strong></span>
            <span class="d-none d-md-inline" style="color: var(--color-outline);">&middot;</span>
            <span><i class="lucide-code-2"></i> <strong style="color: var(--color-on-surface);">60+ unit tests</strong></span>
            <span class="d-none d-md-inline" style="color: var(--color-outline);">&middot;</span>
            <span><i class="lucide-smartphone"></i> <strong style="color: var(--color-on-surface);">Material Design 3</strong></span>
            <span class="d-none d-md-inline" style="color: var(--color-outline);">&middot;</span>
            <span><i class="lucide-lock"></i> <strong style="color: var(--color-on-surface);">Privacy first</strong></span>
        </div>
    </div>
</section>

<!-- ===== HOW IT WORKS ===== -->
<section id="how-it-works" class="reveal">
    <div class="container">
        <div class="section-divider"></div>
        <h2 class="section-title text-center">How It Works<span class="accent-dot">.</span></h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="step-card feature-card">
                    <div class="step-number">1</div>
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-monitor-play"></i></div>
                    <h5 class="fw-bold">Pick your content</h5>
                    <p class="text-muted-brand">Enter a YouTube channel for fresh daily Shorts, paste a specific video URL, or browse curated sleep &amp; meditation suggestions.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card feature-card">
                    <div class="step-number">2</div>
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-alarm-clock"></i></div>
                    <h5 class="fw-bold">Set your alarm</h5>
                    <p class="text-muted-brand">Choose the time, select which days, and fine-tune playback settings like volume, replays, and rising volume.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card feature-card">
                    <div class="step-number">3</div>
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-sunrise"></i></div>
                    <h5 class="fw-bold">Wake up inspired</h5>
                    <p class="text-muted-brand">Your video plays full-screen — even over your lock screen. A new Short every day keeps it fresh. Snooze or dismiss with one swipe.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== FEATURES ===== -->
<section id="features" class="reveal">
    <div class="container">
        <h2 class="section-title text-center">Features<span class="accent-dot">.</span></h2>

        <!-- Hero Features -->
        <div class="row g-4 mb-5">
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-crosshair"></i></div>
                    <h5 class="fw-bold">Fresh Content Daily</h5>
                    <p class="text-muted-brand mb-0">Automatically finds the newest Short from your chosen channel — a different video every morning.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-shield-check"></i></div>
                    <h5 class="fw-bold">Reliable Delivery</h5>
                    <p class="text-muted-brand mb-0">Uses Android's exact alarm API — survives Doze mode and reboots.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-moon-star"></i></div>
                    <h5 class="fw-bold">Sleep Timer</h5>
                    <p class="text-muted-brand mb-0">Fall asleep to meditation, ambient, or lo-fi videos. Run multiple countdown timers at once, volume fades gradually, and curated sleep videos are suggested.</p>
                </div>
            </div>
        </div>

        <!-- Customize Every Alarm -->
        <p class="feature-category-title"><i class="lucide-settings" style="font-size: 1rem; margin-right: 0.4rem;"></i> Customize Every Alarm</p>
        <div class="row g-4 mb-5">
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-sliders-horizontal"></i></div>
                    <h5 class="fw-bold">Per-Alarm Customization <span class="badge bg-accent-subtle text-accent-pro small">Pro</span></h5>
                    <p class="text-muted-brand mb-0">Different channel, volume, replays, and duration for each alarm.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-volume-2"></i></div>
                    <h5 class="fw-bold">Rising Volume <span class="badge bg-accent-subtle text-accent-pro small">Pro</span></h5>
                    <p class="text-muted-brand mb-0">Gentle wake-up: volume ramps from whisper to full over 30 seconds.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-list-video"></i></div>
                    <h5 class="fw-bold">Playlist Mode <span class="badge bg-accent-subtle text-accent-pro small">Pro</span></h5>
                    <p class="text-muted-brand mb-0">Play multiple Shorts in sequence — skip blocked videos automatically.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-clapperboard"></i></div>
                    <h5 class="fw-bold">Specific Video <span class="badge bg-accent-subtle text-accent-pro small">Pro</span></h5>
                    <p class="text-muted-brand mb-0">Paste any YouTube URL — a motivational speech, your favorite song, a calming video — and wake up to that exact video every time.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-tag"></i></div>
                    <h5 class="fw-bold">Alarm Labels</h5>
                    <p class="text-muted-brand mb-0">Name your alarms so you know exactly why they're going off. Labels display on the alarm screen.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-calendar-range"></i></div>
                    <h5 class="fw-bold">Interval Scheduling <span class="badge bg-accent-subtle text-accent-pro small">Pro</span></h5>
                    <p class="text-muted-brand mb-0">Schedule alarms every X days from a start date — perfect for reminders that don't follow a weekly pattern.</p>
                </div>
            </div>
        </div>

        <!-- Built for Heavy Sleepers -->
        <p class="feature-category-title"><i class="lucide-alarm-clock-off" style="font-size: 1rem; margin-right: 0.4rem;"></i> Built for Heavy Sleepers</p>
        <div class="row g-4 mb-5">
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-alarm-clock-minus"></i></div>
                    <h5 class="fw-bold">Smart Snooze <span class="badge bg-accent-subtle text-accent-pro small">Pro</span></h5>
                    <p class="text-muted-brand mb-0">Configurable snooze duration that progressively shortens each time — nudging you awake faster.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-lock-keyhole"></i></div>
                    <h5 class="fw-bold">Dismiss Challenges <span class="badge bg-accent-subtle text-accent-pro small">Pro</span></h5>
                    <p class="text-muted-brand mb-0">Force yourself awake with math problems, shake-to-dismiss, QR code scanning, barcode scanning, or typing challenges. Configurable difficulty and shake count.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-alarm-clock-check"></i></div>
                    <h5 class="fw-bold">Wake-Up Confirmation <span class="badge bg-accent-subtle text-accent-pro small">Pro</span></h5>
                    <p class="text-muted-brand mb-0">After dismissing, a confirmation screen ensures you're actually awake — with optional motion detection and configurable timeout.</p>
                </div>
            </div>
        </div>

        <!-- Stay Accountable -->
        <p class="feature-category-title"><i class="lucide-target" style="font-size: 1rem; margin-right: 0.4rem;"></i> Stay Accountable</p>
        <div class="row g-4 mb-5">
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-bar-chart-3"></i></div>
                    <h5 class="fw-bold">Streak, Stats &amp; Badges</h5>
                    <p class="text-muted-brand mb-0">Track your alarm streak, weekly count, snooze rate, dismiss spread, and average wake time. Earn badges for consistency milestones.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-users"></i></div>
                    <h5 class="fw-bold">Alarm with Friends</h5>
                    <p class="text-muted-brand mb-0">Create or join friend groups and share alarm metrics — streaks, snooze rates, wake times, and 7-day activity. Hold each other accountable.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-calendar-off"></i></div>
                    <h5 class="fw-bold">Skip Dates</h5>
                    <p class="text-muted-brand mb-0">Mark holidays or days off so your alarm silently skips — no need to toggle anything.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-hand"></i></div>
                    <h5 class="fw-bold">Swipe Gestures</h5>
                    <p class="text-muted-brand mb-0">Swipe down to dismiss, swipe left to snooze — fast controls when you're half asleep. Toggle on or off in settings.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-archive"></i></div>
                    <h5 class="fw-bold">Alarm Archive <span class="badge bg-accent-subtle text-accent-pro small">Pro</span></h5>
                    <p class="text-muted-brand mb-0">Soft-delete alarms to keep their history and stats. Toggle recording on or off per alarm.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-flask-conical"></i></div>
                    <h5 class="fw-bold">Test Alarm</h5>
                    <p class="text-muted-brand mb-0">Preview the full alarm experience before you rely on it — test from settings anytime.</p>
                </div>
            </div>
        </div>

        <!-- Built for Peace of Mind -->
        <p class="feature-category-title"><i class="lucide-heart" style="font-size: 1rem; margin-right: 0.4rem;"></i> Built for Peace of Mind</p>
        <div class="row g-4">
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-cloud-upload"></i></div>
                    <h5 class="fw-bold">Auto Backup</h5>
                    <p class="text-muted-brand mb-0">Alarms and settings are backed up automatically via Android. Reinstall and pick up where you left off.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-moon"></i></div>
                    <h5 class="fw-bold">Dark Mode</h5>
                    <p class="text-muted-brand mb-0">Switch between System, Light, and Dark themes. Your preference is saved and applied instantly.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-lightbulb"></i></div>
                    <h5 class="fw-bold">Channel Suggestions</h5>
                    <p class="text-muted-brand mb-0">Not sure which channel to pick? Curated suggestions help you discover great wake-up content.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-alarm-clock-check"></i></div>
                    <h5 class="fw-bold">Default Alarm App</h5>
                    <p class="text-muted-brand mb-0">Set YT Shorts Alarm as your default Android alarm handler — setting alarms from the clock app or Google Assistant launches directly into the app.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true"><i class="lucide-shield"></i></div>
                    <h5 class="fw-bold">Privacy First</h5>
                    <p class="text-muted-brand mb-0">No accounts. No tracking. No ads. All data stays on your device.</p>
                </div>
            </div>
        </div>
    </div>
</section>

