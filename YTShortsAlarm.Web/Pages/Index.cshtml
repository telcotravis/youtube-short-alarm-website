@page
@model IndexModel
@{
    ViewData["Title"] = "Wake Up to YouTube Shorts";
}

<!-- ===== HERO ===== -->
<section id="hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="display-3 fw-bold mb-3">
                    Wake up to your favorite <span class="text-accent">YouTube Shorts</span>
                </h1>
                <p class="lead mb-4 text-muted-brand">
                    YT Shorts Alarm plays the latest Short from any YouTube channel as your alarm. No more boring beeps.
                </p>
                <span class="badge bg-warning text-dark fs-6 px-3 py-2 mb-4 d-inline-block">Coming Soon on Google Play</span>

                <form method="post" asp-page-handler="Signup" class="signup-form">
                    <div class="input-group">
                        <input type="email" asp-for="Input.Email" class="form-control" placeholder="you@example.com" aria-label="Email address" />
                        <button type="submit" class="btn btn-cta">Notify Me</button>
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </form>

            </div>
            <div class="col-lg-6 text-center mt-5 mt-lg-0">
                <img src="~/images/hero-banner.jpg" alt="YT Shorts Alarm — your morning, powered by fresh video" class="img-fluid rounded-4 shadow-lg" loading="eager" />
            </div>
        </div>
    </div>
</section>

<!-- ===== HOW IT WORKS ===== -->
<section id="how-it-works">
    <div class="container">
        <h2 class="section-title text-center">How It Works<span class="accent-dot">.</span></h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="step-card feature-card">
                    <div class="step-number">1</div>
                    <div class="feature-icon" aria-hidden="true">📺</div>
                    <h5 class="fw-bold">Pick a channel</h5>
                    <p class="text-muted-brand">Enter a YouTube @@handle, channel URL, or channel ID. Each alarm can have its own channel.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card feature-card">
                    <div class="step-number">2</div>
                    <div class="feature-icon" aria-hidden="true">⏰</div>
                    <h5 class="fw-bold">Set your alarm</h5>
                    <p class="text-muted-brand">Choose the time, select which days, and fine-tune playback settings like volume, replays, and rising volume.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card feature-card">
                    <div class="step-number">3</div>
                    <div class="feature-icon" aria-hidden="true">🌅</div>
                    <h5 class="fw-bold">Wake up inspired</h5>
                    <p class="text-muted-brand">When your alarm fires, the latest Short plays full-screen — even over your lock screen. Snooze with smart progressive timing or dismiss.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== FEATURES ===== -->
<section id="features">
    <div class="container">
        <h2 class="section-title text-center">Features<span class="accent-dot">.</span></h2>
        <div class="row g-4">
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true">🎯</div>
                    <h5 class="fw-bold">Smart Video Selection</h5>
                    <p class="text-muted-brand mb-0">Automatically finds the newest embeddable Short from your chosen channel.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true">⚙️</div>
                    <h5 class="fw-bold">Per-Alarm Customization <span class="badge bg-accent-subtle text-accent small">Pro</span></h5>
                    <p class="text-muted-brand mb-0">Different channel, volume, replays, and duration for each alarm.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true">🔒</div>
                    <h5 class="fw-bold">Reliable Delivery</h5>
                    <p class="text-muted-brand mb-0">Uses Android's exact alarm API — survives Doze mode and reboots.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true">🔊</div>
                    <h5 class="fw-bold">Rising Volume <span class="badge bg-accent-subtle text-accent small">Pro</span></h5>
                    <p class="text-muted-brand mb-0">Gentle wake-up: volume ramps from whisper to full over 30 seconds.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true">📋</div>
                    <h5 class="fw-bold">Playlist Mode <span class="badge bg-accent-subtle text-accent small">Pro</span></h5>
                    <p class="text-muted-brand mb-0">Play multiple Shorts in sequence — skip blocked videos automatically.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true">�</div>
                    <h5 class="fw-bold">Interval Scheduling <span class="badge bg-accent-subtle text-accent small">Pro</span></h5>
                    <p class="text-muted-brand mb-0">Schedule alarms every X days from a start date — perfect for reminders that don't follow a weekly pattern.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true">🏷️</div>
                    <h5 class="fw-bold">Alarm Labels</h5>
                    <p class="text-muted-brand mb-0">Name your alarms so you know exactly why they're going off. Labels display on the alarm screen.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">                    <div class="feature-icon" aria-hidden="true">🎬</div>
                    <h5 class="fw-bold">Specific Video <span class="badge bg-accent-subtle text-accent small">Pro</span></h5>
                    <p class="text-muted-brand mb-0">Paste a YouTube URL to wake up to an exact video instead of a random Short from the channel.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true">�</div>
                    <h5 class="fw-bold">Smart Snooze <span class="badge bg-accent-subtle text-accent small">Pro</span></h5>
                    <p class="text-muted-brand mb-0">Configurable snooze duration that progressively shortens each time — nudging you awake faster.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true">📅</div>
                    <h5 class="fw-bold">Skip Dates</h5>
                    <p class="text-muted-brand mb-0">Mark holidays or days off so your alarm silently skips — no need to toggle anything.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true">📊</div>
                    <h5 class="fw-bold">Streak &amp; Stats</h5>
                    <p class="text-muted-brand mb-0">Track your alarm streak, weekly count, snooze rate, and average snoozes on the dashboard.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true">👆</div>
                    <h5 class="fw-bold">Swipe Gestures</h5>
                    <p class="text-muted-brand mb-0">Swipe down to dismiss, swipe left to snooze — fast controls when you're half asleep. Toggle on or off in settings.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true">🧪</div>
                    <h5 class="fw-bold">Test Alarm</h5>
                    <p class="text-muted-brand mb-0">Preview the full alarm experience before you rely on it — test from settings anytime.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true">☁️</div>
                    <h5 class="fw-bold">Auto Backup</h5>
                    <p class="text-muted-brand mb-0">Alarms and settings are backed up automatically via Android. Reinstall and pick up where you left off.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">                    <div class="feature-icon" aria-hidden="true">💡</div>
                    <h5 class="fw-bold">Channel Suggestions</h5>
                    <p class="text-muted-brand mb-0">Not sure which channel to pick? Curated suggestions help you discover great wake-up content.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" aria-hidden="true">�🛡️</div>
                    <h5 class="fw-bold">Privacy First</h5>
                    <p class="text-muted-brand mb-0">No accounts. No tracking. No ads. All data stays on your device.</p>
                </div>
            </div>
        </div>
    </div>
</section>

