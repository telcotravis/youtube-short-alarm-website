<!-- ===== TECH HIGHLIGHTS ===== -->
<section id="tech" class="reveal">
    <div class="container">
        <h2 class="section-title text-center">Built Right<span class="accent-dot">.</span></h2>
        <div class="row justify-content-center g-4">
            <div class="col-6 col-md-3">
                <div class="tech-stat">
                    <div class="stat-value">60+</div>
                    <div class="stat-label">Unit Tests</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="tech-stat">
                    <div class="stat-value">0</div>
                    <div class="stat-label">Tracking SDKs</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="tech-stat">
                    <div class="stat-value">10+</div>
                    <div class="stat-label">Android Versions</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="tech-stat">
                    <div class="stat-value">M3</div>
                    <div class="stat-label">Material Design</div>
                </div>
            </div>
        </div>
        <div class="d-flex flex-wrap justify-content-center gap-2 mt-4">
            @foreach (var badge in new[] { "Encrypted Storage", "YouTube Data API v3", "Export/Import", "Auto Backup", "Foldable & Tablet Support", "Smart Snooze", "Sleep Timer", "Dismiss Challenges" })
            {
                <span class="tech-badge">@badge</span>
            }
        </div>
    </div>
</section>

<!-- ===== FAQ ===== -->
<section id="faq" class="reveal">
    <div class="container">
        <h2 class="section-title text-center">Frequently Asked Questions<span class="accent-dot">.</span></h2>
        <div class="accordion mx-auto" id="faqAccordion" style="max-width: 800px;">

            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1" aria-expanded="true" aria-controls="faq1">
                        Is YT Shorts Alarm free?
                    </button>
                </h3>
                <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">The core app is free — one alarm with full playback, snooze, and dismiss. A one-time Pro upgrade unlocks unlimited alarms, per-alarm overrides, interval scheduling, rising volume, smart progressive snooze, playlist mode, and export/import. No ads, no subscriptions.</div>
                </div>
            </div>

            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2" aria-expanded="false" aria-controls="faq2">
                        What happens if I have no internet when the alarm fires?
                    </button>
                </h3>
                <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">The app falls back to your device's default alarm tone within 15 seconds. Your alarm always goes off.</div>
                </div>
            </div>

            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3" aria-expanded="false" aria-controls="faq3">
                        Does it work with any YouTube channel?
                    </button>
                </h3>
                <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">Yes — enter a @@handle, channel URL, or channel ID. The app finds the latest embeddable Short-style video.</div>
                </div>
            </div>

            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4" aria-expanded="false" aria-controls="faq4">
                        Will my alarm go off after a reboot?
                    </button>
                </h3>
                <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">Yes. All alarms are rescheduled automatically after your device restarts.</div>
                </div>
            </div>

            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq5" aria-expanded="false" aria-controls="faq5">
                        Does the app drain my battery?
                    </button>
                </h3>
                <div id="faq5" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">No. The app does nothing between alarms. It uses Android's native AlarmManager which is battery-optimized.</div>
                </div>
            </div>

            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq6" aria-expanded="false" aria-controls="faq6">
                        Why does the app need so many permissions?
                    </button>
                </h3>
                <div id="faq6" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">Each permission is essential for alarm reliability: exact timing, waking the screen, surviving battery optimization, and showing notifications.</div>
                </div>
            </div>

            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq7" aria-expanded="false" aria-controls="faq7">
                        Can I use a specific video instead of a random Short?
                    </button>
                </h3>
                <div id="faq7" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">Yes — Pro users can paste a YouTube video URL directly into an alarm. The app will play that exact video instead of searching for the latest Short from a channel.</div>
                </div>
            </div>

            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq8" aria-expanded="false" aria-controls="faq8">
                        Will my alarms be restored if I reinstall the app?
                    </button>
                </h3>
                <div id="faq8" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">Yes. The app uses Android's automatic backup system, so your alarms and settings are restored when you reinstall. You can also manually export your configuration as a JSON file from Settings.</div>
                </div>
            </div>

            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq9" aria-expanded="false" aria-controls="faq9">
                        Can I test the alarm before going to sleep?
                    </button>
                </h3>
                <div id="faq9" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">Yes. There's a "Test Alarm" button in Settings that launches the full alarm experience — video playback, vibration, and all — so you can verify everything works.</div>
                </div>
            </div>

            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq10" aria-expanded="false" aria-controls="faq10">
                        Does it work on tablets and foldables?
                    </button>
                </h3>
                <div id="faq10" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">Yes. The app supports responsive layouts for large screens and adapts to foldable devices, including table-top postures.</div>
                </div>
            </div>

            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq11" aria-expanded="false" aria-controls="faq11">
                        What is Smart Snooze?
                    </button>
                </h3>
                <div id="faq11" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">Smart Snooze (Pro) progressively shortens your snooze time each time you hit snooze. For example, with a 10-minute starting duration and 30% reduction, your snoozes go 10 → 7 → 5 → 3 minutes. You can configure the initial duration, reduction percentage, and maximum number of snoozes.</div>
                </div>
            </div>

            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq12" aria-expanded="false" aria-controls="faq12">
                        Can I skip alarms on holidays?
                    </button>
                </h3>
                <div id="faq12" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">Yes. Each alarm has a Skip Dates option where you can mark specific dates to skip. The alarm silently skips those dates and fires normally on all other scheduled days.</div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- ===== FINAL CTA ===== -->
<section id="download" class="py-5">
    <div class="container text-center py-5">
        <h2 class="display-5 fw-bold mb-4">Ready to wake up differently?</h2>

        <form method="post" asp-page-handler="Signup" class="signup-form mx-auto">
            <div class="input-group">
                <input type="email" asp-for="Input.Email" class="form-control" placeholder="you@example.com" aria-label="Email address" />
                <button type="submit" class="btn btn-cta">Get Early Access</button>
            </div>
            <span asp-validation-for="Input.Email" class="text-danger small"></span>
        </form>

        @if (TempData["SignupMessage"] != null)
        {
            <div class="alert alert-success alert-signup mx-auto mt-3" role="alert">@TempData["SignupMessage"]</div>
        }
        @if (TempData["SignupError"] != null)
        {
            <div class="alert alert-danger alert-signup mx-auto mt-3" role="alert">@TempData["SignupError"]</div>
        }

        <div class="trust-icons d-flex justify-content-center gap-4 mt-3 text-muted-brand small">
            <span><i class="lucide-shield"></i> No spam</span>
            <span><i class="lucide-eye-off"></i> No tracking</span>
            <span><i class="lucide-gift"></i> Free to start</span>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
    document.addEventListener('DOMContentLoaded', function () {
        var buttons = document.querySelectorAll('.theme-toggle-btn');
        var darkGroup = document.getElementById('screenshots-dark');
        var lightGroup = document.getElementById('screenshots-light');

        buttons.forEach(function (btn) {
            btn.addEventListener('click', function () {
                var theme = this.getAttribute('data-theme');
                buttons.forEach(function (b) {
                    b.classList.remove('active');
                    b.setAttribute('aria-pressed', 'false');
                });
                this.classList.add('active');
                this.setAttribute('aria-pressed', 'true');

                if (theme === 'dark') {
                    darkGroup.classList.remove('d-none');
                    lightGroup.classList.add('d-none');
                } else {
                    lightGroup.classList.remove('d-none');
                    darkGroup.classList.add('d-none');
                }
            });
        });
    });
    </script>

