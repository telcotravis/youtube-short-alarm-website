@page
@model YTShortsAlarm.Web.Pages.Admin.WaitlistModel
@{
    ViewData["Title"] = "Waitlist";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Waitlist Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <meta name="robots" content="noindex, nofollow" />
</head>
<body class="bg-dark text-light">
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Waitlist Signups <span class="badge bg-primary">@Model.Entries.Count</span></h1>
        <div>
            <a href="/admin/waitlist?key=@Model.Key&handler=ExportCsv" class="btn btn-outline-light me-2">Export CSV</a>
            @if (Model.Entries.Count > 0)
            {
                <form method="post" asp-page-handler="ClearAll" class="d-inline" onsubmit="return confirm('Are you sure you want to delete all @Model.Entries.Count waitlist entries? This cannot be undone.');">
                    <input type="hidden" name="key" value="@Model.Key" />
                    <button type="submit" class="btn btn-outline-danger">Clear Waitlist</button>
                </form>
            }
        </div>
    </div>

    @if (Model.Entries.Count == 0)
    {
        <div class="alert alert-secondary">No signups yet.</div>
    }
    else
    {
        <table class="table table-dark table-striped table-hover">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Email</th>
                    <th>Signed Up (UTC)</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var (entry, index) in Model.Entries.Select((e, i) => (e, i + 1)))
            {
                <tr>
                    <td>@index</td>
                    <td>@entry.Email</td>
                    <td>@entry.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
            }
            </tbody>
        </table>
    }
</div>
</body>
</html>
