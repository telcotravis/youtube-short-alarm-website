<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} - YT Shorts Alarm" : "YT Shorts Alarm")</title>

    <!-- SEO -->
    <meta name="description" content="@(ViewData["MetaDescription"] ?? "YT Shorts Alarm wakes you with a fresh YouTube Short every day, a specific video you choose, or a sleep timer for meditation. No more boring alarms.")" />
    <meta name="keywords" content="YouTube Shorts, alarm, wake up, Android app, YouTube alarm clock, smart snooze, sleep timer, meditation, specific video, alarm streak, skip dates" />
    <link rel="canonical" href="@(ViewData["CanonicalUrl"] ?? "https://ytshortsalarm.kardsen.com")" />

    <!-- Open Graph -->
    <meta property="og:title" content="@(ViewData["Title"] ?? "YT Shorts Alarm")" />
    <meta property="og:description" content="@(ViewData["MetaDescription"] ?? "A fresh Short every morning, a specific video you pick, or a sleep timer for meditation. Your alarm, your content.")" />
    <meta property="og:image" content="https://ytshortsalarm.kardsen.com/images/hero-banner.jpg" />
    <meta property="og:url" content="@(ViewData["CanonicalUrl"] ?? "https://ytshortsalarm.kardsen.com")" />
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@(ViewData["Title"] ?? "YT Shorts Alarm")" />
    <meta name="twitter:description" content="@(ViewData["MetaDescription"] ?? "A fresh Short every morning, a specific video you pick, or a sleep timer for meditation. Your alarm, your content.")" />
    <meta name="twitter:image" content="https://ytshortsalarm.kardsen.com/images/hero-banner.jpg" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="~/images/app-icon.png" />

    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" />

    <!-- Lucide Icons -->
    <link rel="stylesheet" href="https://unpkg.com/lucide-static@latest/font/lucide.min.css" />

    <!-- Preload hero image -->
    <link rel="preload" as="image" href="/images/hero-banner.jpg" />

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "SoftwareApplication",
        "name": "YT Shorts Alarm",
        "operatingSystem": "Android 10+",
        "applicationCategory": "UtilitiesApplication",
        "description": "An alarm clock that plays the latest YouTube Short from any channel. Free, private, no ads.",
        "offers": [
            {
                "@@type": "Offer",
                "price": "0",
                "priceCurrency": "USD",
                "description": "Free tier with 30-day Pro trial"
            },
            {
                "@@type": "Offer",
                "price": "3.99",
                "priceCurrency": "USD",
                "description": "Pro Monthly subscription",
                "priceSpecification": {
                    "@@type": "UnitPriceSpecification",
                    "billingDuration": "P1M"
                }
            },
            {
                "@@type": "Offer",
                "price": "9.99",
                "priceCurrency": "USD",
                "description": "Founding Member Lifetime unlock"
            }
        ],
        "author": {
            "@@type": "Organization",
            "name": "Kardsen"
        },
        "softwareVersion": "1.9",
        "image": "https://ytshortsalarm.kardsen.com/images/app-icon.png",
        "screenshot": "https://ytshortsalarm.kardsen.com/images/hero-banner.jpg"
    }
    </script>
</head>
<body data-bs-theme="dark">

    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top" style="background-color: rgba(17, 19, 24, 0.95); backdrop-filter: blur(10px);">
        <div class="container">
            <a class="navbar-brand fw-bold d-flex align-items-center" href="/">
                <img src="~/images/app-icon.png" alt="" width="32" height="32" class="me-2 rounded" />
                <span class="brand-yt">YT</span> Shorts Alarm
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/#features">Features</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/#screenshots">Screenshots</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/#faq">FAQ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Guide">Guide</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Changelog">Changelog</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Privacy">Privacy</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="py-5 mt-5">
        <div class="container">
            <div class="row align-items-start">
                <div class="col-md-4 mb-3">
                    <div class="d-flex align-items-center mb-2">
                        <img src="~/images/app-icon.png" alt="" width="24" height="24" class="me-2 rounded" />
                        <span class="fw-bold">YT Shorts Alarm</span>
                    </div>
                    <p class="text-muted-brand mb-0 small">&copy; 2026 Kardsen. All rights reserved.</p>
                </div>
                <div class="col-md-4 mb-3 text-md-center">
                    <a asp-page="/Privacy">Privacy Policy</a>
                    <span class="text-muted-brand mx-2">|</span>
                    <a asp-page="/Guide">Guide</a>
                    <span class="text-muted-brand mx-2">|</span>
                    <a href="mailto:support@kardsen.com">Contact</a>
                </div>
                <div class="col-md-4 mb-3 text-md-end">
                    <small class="text-muted-brand d-block">
                        This app uses YouTube API Services.
                    </small>
                    <small class="text-muted-brand d-block mt-1">
                        <a href="https://www.youtube.com/t/terms" target="_blank" rel="noopener noreferrer">YouTube ToS</a>
                        <span class="mx-1">|</span>
                        <a href="https://www.google.com/policies/privacy" target="_blank" rel="noopener noreferrer">Google Privacy Policy</a>
                    </small>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap 5.3 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Site JS -->
    <script src="~/js/site.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
